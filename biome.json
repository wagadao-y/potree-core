{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!apps/playground/public/data",
      "!apps/benchmark-decode/src/legacy-brotli"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noTsIgnore": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/core/src/loading2/*.worker.js",
        "packages/core/src/workers/*.js"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "useArrowFunction": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noSwitchDeclarations": "off",
            "useParseIntRadix": "off"
          },
          "style": {
            "useConst": "off"
          },
          "suspicious": {
            "noAssignInExpressions": "off",
            "noDebugger": "off",
            "noDoubleEquals": "off",
            "noGlobalAssign": "off",
            "noGlobalIsNan": "off",
            "noImplicitAnyLet": "off",
            "noSelfCompare": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/core/src/utils/binary-heap.js"],
      "linter": {
        "rules": {
          "complexity": {
            "useArrowFunction": "off"
          },
          "correctness": {
            "noInnerDeclarations": "off"
          }
        }
      }
    }
  ]
}

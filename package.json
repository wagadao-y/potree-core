{
  "name": "@own-potree-core/root",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter playground build",
    "typecheck": "pnpm --filter potree-core typecheck && pnpm --filter playground typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "preview": "pnpm --filter playground preview",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "update": "pnpm exec ncu --workspaces"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "npm-check-updates": "^21.0.3"
  }
}

{
  "name": "potree-core",
  "version": "2.0.15",
  "description": "Potree wrapper for three.js applications",
  "repository": {
    "type": "git",
    "url": "https://github.com/tentone/potree-core.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "docs": "typedoc source/** --out docs --tsconfig tsconfig.json --theme default --excludeExternals --excludeNotDocumented",
    "pub": "npm run docs && npm publish --access public ."
  },
  "keywords": [
    "three",
    "potree",
    "3d",
    "webgl"
  ],
  "author": "Tentone",
  "license": "MIT",
  "peerDependencies": {
    "three": ">0.125.0"
  },
  "dependencies": {
    "brotli": "1.3.3"
  },
  "devDependencies": {
    "@types/node": "20.8.4",
    "@types/three": "^0.152.1",
    "three": "^0.154.0",
    "typedoc": "0.28.5",
    "typescript": "5.5.4"
  }
}

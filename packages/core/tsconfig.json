{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./src",
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "target": "es2022",
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "types": ["vite/client"],
    "lib": ["es2022", "dom", "esnext.disposable"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}

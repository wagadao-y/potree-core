{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./src/",
    "sourceMap": true,
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "alwaysStrict": false,
    "target": "es2020",
    "experimentalDecorators": true,
    "types": ["vite/client"],
    "lib": ["es2020", "dom"],
    "plugins": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}

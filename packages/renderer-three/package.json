{
  "name": "potree-renderer-three",
  "version": "2.0.15",
  "description": "Three.js renderer integration for potree-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/tentone/potree-core.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm --filter potree-core build && pnpm run clean && vite build && tsc --project tsconfig.json",
    "typecheck": "pnpm --filter potree-core build && tsc --noEmit --emitDeclarationOnly false --project tsconfig.json"
  },
  "keywords": [
    "three",
    "potree",
    "3d",
    "webgl"
  ],
  "author": "Tentone",
  "license": "MIT",
  "dependencies": {
    "potree-core": "workspace:*"
  },
  "peerDependencies": {
    "three": ">0.125.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "three": "^0.184.0",
    "typescript": "6.0.3",
    "vite": "^8.0.9"
  }
}
